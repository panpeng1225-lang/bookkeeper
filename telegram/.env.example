# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_PORT=8787
TELEGRAM_BOT_HOST=0.0.0.0
TELEGRAM_DEFAULT_CURRENCY=RMB

# Volcengine Speech-to-Text
# Old console mode:
VOLCENGINE_SPEECH_APPID=
VOLCENGINE_SPEECH_TOKEN=

# New console mode:
VOLCENGINE_SPEECH_API_KEY=

# Shared options
VOLCENGINE_SPEECH_LANGUAGE=zh-CN
VOLCENGINE_SPEECH_USE_ITN=true
VOLCENGINE_SPEECH_USE_PUNC=false
VOLCENGINE_SPEECH_RESOURCE_ID=volc.seedasr.auc
VOLCENGINE_SPEECH_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
VOLCENGINE_SPEECH_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLCENGINE_SPEECH_POLL_MS=1500
VOLCENGINE_SPEECH_TIMEOUT_MS=45000
